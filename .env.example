NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider — "anthropic" (default) or "deepseek". Read at request time
# in lib/env.ts so toggling in Vercel takes effect without redeploy. The
# rollback path for the DeepSeek migration is "set this back to anthropic".
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Tavily Search API — required when LLM_PROVIDER=deepseek (DeepSeek has no
# server-side web search; we run search ourselves and feed results back in
# a tool-call loop). Sign up at https://tavily.com.
TAVILY_API_KEY=

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
ADMIN_EMAIL=
GENERATION_ENABLED=true
DAILY_COST_CEILING_USD=10.00
SLACK_WEBHOOK_URL=
